{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pmfleming/qmlqualitylens/qmlqualitylens.schema.json",
  "title": "qmlqualitylens config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "project_name": { "type": "string" },
    "project_root": { "type": "string" },
    "source_roots": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "output_dir": { "type": "string" },
    "exclude": { "type": "array", "items": { "type": "string" } },
    "qmllint_report": { "type": "string" },
    "qmllint_command": { "type": "string" },
    "external_modules": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "external_types": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "suppressions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "anyOf": [
          { "required": ["id"] },
          { "required": ["kind"] },
          { "required": ["file"] }
        ],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "file": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "process_boundary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "objectTypes": { "type": "array", "items": { "type": "string" } },
        "textPatterns": { "type": "array", "items": { "type": "string" } },
        "allowedFilePatterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fileSlocHigh": { "type": "number", "exclusiveMinimum": 0 },
        "componentObjectCountHigh": { "type": "number", "exclusiveMinimum": 0 },
        "functionCyclomaticHigh": { "type": "number", "exclusiveMinimum": 0 },
        "functionCognitiveHigh": { "type": "number", "exclusiveMinimum": 0 },
        "handlerLinesHigh": { "type": "number", "exclusiveMinimum": 0 },
        "bindingComplexityHigh": { "type": "number", "exclusiveMinimum": 0 },
        "cloneWindow": { "type": "integer", "minimum": 2 }
      }
    }
  }
}
